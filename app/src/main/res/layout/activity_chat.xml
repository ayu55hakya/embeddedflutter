<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#EDE7F6">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:titleTextColor="@android:color/white"
        app:subtitleTextColor="#CCFFFFFF" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_chat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingVertical="8dp" />

    <!-- Typing indicator -->
    <LinearLayout
        android:id="@+id/ll_typing"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="4dp"
        android:visibility="gone">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="34dp"
            android:layout_height="34dp"
            app:cardBackgroundColor="#6750A4"
            app:cardCornerRadius="17dp"
            app:cardElevation="0dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="A"
                android:gravity="center"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="14sp" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="18dp"
            app:cardElevation="1dp">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp"
                android:gravity="center_vertical">
                <TextView android:id="@+id/tv_dot1"
                    android:layout_width="8dp" android:layout_height="8dp"
                    android:background="#6750A4" android:text="" />
                <TextView android:id="@+id/tv_dot2"
                    android:layout_width="8dp" android:layout_height="8dp"
                    android:background="#6750A4" android:text=""
                    android:layout_marginHorizontal="4dp" />
                <TextView android:id="@+id/tv_dot3"
                    android:layout_width="8dp" android:layout_height="8dp"
                    android:background="#6750A4" android:text="" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Alex is typing…"
            android:textSize="12sp"
            android:textColor="#9E9E9E"
            android:textStyle="italic" />
    </LinearLayout>

    <!-- Input bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="bottom"
        android:padding="8dp"
        android:background="@android:color/white"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btn_attach"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_add"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#6750A4"
            android:contentDescription="Attach" />

        <EditText
            android:id="@+id/et_message"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Message"
            android:background="@null"
            android:maxLines="4"
            android:inputType="textMultiLine|textCapSentences"
            android:paddingHorizontal="8dp" />

        <ImageButton
            android:id="@+id/btn_mic_send"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_btn_speak_now"
            android:background="@null"
            android:tint="#6750A4"
            android:contentDescription="Send or Record" />
    </LinearLayout>

</LinearLayout>
